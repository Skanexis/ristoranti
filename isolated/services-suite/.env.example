# Services suite standalone env template

HOST=0.0.0.0
PORT=3000
NODE_ENV=production

# Dedicated Services consultant bot
TELEGRAM_SERVICES_BOT_TOKEN=
TELEGRAM_SERVICES_BOT_USERNAME=
TELEGRAM_SERVICES_BOT_MODE=webhook

# Public page used by services bot in messages
SERVICES_PAGE_URL=https://example.com/services
SERVICES_CONTACT_TELEGRAM=SHLC26

# Optional direct bot URL override
# TELEGRAM_SERVICES_BOT_URL=https://t.me/your_services_bot

# Optional lead notifications
# TELEGRAM_SERVICES_ADMIN_CHAT_ID=123456789

# Optional operator relay via forum topics
# TELEGRAM_SERVICES_OPERATOR_GROUP_ID=-1001234567890
# TELEGRAM_SERVICES_OPERATOR_USER_IDS=123456789,987654321

# Services bot webhook settings (if TELEGRAM_SERVICES_BOT_MODE=webhook)
TELEGRAM_SERVICES_WEBHOOK_BASE_URL=https://example.com
TELEGRAM_SERVICES_WEBHOOK_PATH=/telegram/services-webhook
TELEGRAM_SERVICES_WEBHOOK_SECRET=replace_with_random_services_secret
TELEGRAM_SERVICES_WEBHOOK_BIND_HOST=127.0.0.1
TELEGRAM_SERVICES_WEBHOOK_PORT=3100

# Optional allow-list for services bot
# TELEGRAM_SERVICES_ALLOWED_USER_IDS=123456789,987654321

# AI settings for services bot
SERVICES_BOT_OPENAI_API_KEY=
SERVICES_BOT_OPENAI_MODEL=gpt-4o-mini
# SERVICES_BOT_OPENAI_BASE_URL=https://api.openai.com/v1
# SERVICES_BOT_OPENAI_TIMEOUT_MS=25000
